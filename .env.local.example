# Copy this file to .env.local and fill in your keys.
# .env.local is never committed to git.

# ——— Demo Mode ———
# Set to "true" to browse the whole app with a fake coach and 5 sample pieces,
# no login and no other keys needed. Set to "false" for real login.
NEXT_PUBLIC_DEMO_MODE=true

# ——— Supabase (needed for real login, Phase 1+) ———
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ——— Deepgram (Phase 2: voice memo transcription) ———
# From console.deepgram.com → API Keys. Optional: without it, the voice memo
# step politely offers a skip instead of transcribing.
DEEPGRAM_API_KEY=

# ——— Coming in later phases ———
# ANTHROPIC_API_KEY=       (Phase 4: moment-finding and writing)
